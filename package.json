{
  "name": "hsp",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "tests/runners/ts"
  ],
  "scripts": {
    "check": "npm run typecheck --workspaces --if-present && npm run typecheck:examples && npm run guard -w @hsp/core && npm run verify -w hsp-conformance-runner",
    "typecheck:examples": "tsc -p examples",
    "guard": "npm run guard -w @hsp/core",
    "verify": "npm run verify -w hsp-conformance-runner",
    "e2e:public": "npm run e2e:public -w hsp-conformance-runner",
    "e2e:anvil": "npm run e2e:anvil -w hsp-conformance-runner",
    "e2e:compliance": "npm run e2e:compliance -w hsp-conformance-runner",
    "test:devkit": "npm run example -w @hsp/devkit && npm run template -w @hsp/devkit",
    "e2e:delegation": "npm run e2e:delegation -w hsp-conformance-runner"
  }
}
