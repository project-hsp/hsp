{
  "name": "hsp-conformance-runner",
  "version": "0.1.0",
  "description": "TypeScript reference runner for the HSP conformance vector pack (tests/vectors/).",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "verify": "tsx src/verify.ts",
    "freeze": "tsx src/freeze.ts",
    "guard": "tsx ../../../packages/core/src/guard.ts",
    "typecheck": "tsc --noEmit",
    "e2e:public": "tsx src/e2e/public.ts",
    "e2e:anvil": "tsx src/e2e/anvil-public.ts",
    "e2e:compliance": "tsx src/e2e/compliance.ts"
  },
  "dependencies": {
    "@hsp/core": "*",
    "viem": "2.52.2"
  },
  "devDependencies": {
    "@types/node": "22.19.17",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
