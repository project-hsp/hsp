{
  "//": "HSP MCP server registration example (copy into your project's .mcp.json, or `claude mcp add hsp -- npx tsx <repo>/packages/mcp/src/index.ts`). This server is PURE / KEY-LESS: it constructs, verifies, and explains HSP wire objects + capabilities + policy — it moves NO money and holds NO key, so there is no agent key and no spend caps. To actually PAY, use @hsp/sdk (HSPClient.pay / payX402). The only required var is HSP_CHAIN; the rest are optional and only widen what hsp_verify can check.",
  "mcpServers": {
    "hsp": {
      "command": "npx",
      "args": ["tsx", "packages/mcp/src/index.ts"],
      "env": {
        "HSP_CHAIN": "anvil-dev",
        "HSP_STABLECOIN_ANVIL_DEV": "0xYOUR_TOKEN:MUSDC:6",
        "HSP_PINNED_ADAPTER_ADDRESS": "0xCOORDINATOR_ADAPTER_ADDRESS",
        "HSP_X402_DOMAINS": "merchant.example.com",
        "HSP_COMPLIANCE_ISSUER": "0xISSUER_ADDRESS"
      }
    }
  }
}
